PORT=8787
API_PUBLIC_URL=http://localhost:8787
ANALYSIS_DATA_DIR=./data/analysis-jobs
# Optional second-stage GPU feature endpoint. Leave blank to use CPU-only analysis.
GPU_FEATURES_URL=
GPU_FEATURES_TOKEN=
GPU_CANDIDATE_LIMIT=240
GPU_BATCH_SIZE=24
GPU_TIMEOUT_MS=120000
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:8787/auth/instagram/callback
# These scopes are for the optional Creator/Business API path. Meta may prompt personal accounts to convert.
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish
